# Copy to .env and fill in. Never commit .env

# Foundry deploy (`contracts/script/DeployDAOVault.s.sol`) — dev key only
# PRIVATE_KEY=
# Optional emergency-pause multisig (see `docs/VAULT_ORACLE_AND_GOVERNANCE.md`)
# GUARDIAN_ADDRESS=

# Chain (Base Sepolia example below — copy into real `.env` + match `frontend` VITE_*)
# CHAIN_RPC_URL=https://sepolia.base.org
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# CHAIN_ID=84532
CHAIN_RPC_URL=
# CHAIN_RPC_URL_FALLBACK=

# Foundry fork tests (`contracts/test/UniswapBaseFork.t.sol`) — defaults to public RPC if unset
# BASE_MAINNET_RPC_URL=

# Basescan API key — contract verification (`forge script ... --verify`)
# BASESCAN_API_KEY=

# Allocation vote snapshot (`npm run cycle:snapshot` in apps/agent)
# VOTE_CYCLE_KEY=1
# CYCLE_SNAPSHOT_BLOCK=
# CYCLE_KEEP_VOTING_OPEN=
# AGGREGATE_STRICT_SHARES=
# Long-running: `npm run agent` (repo root) — sync, stamp, aggregate→targets, votes export, optional trust finalize + auto-rebalance
# AGENT_INTERVAL_SEC=60
# AGENT_AGGREGATE_TARGETS=1
# Only write targets.json when participation meets quorum (same math as dashboard); set 0 to always write
# AGENT_REQUIRE_QUORUM_FOR_TARGETS=1
# AGENT_STAMP_PRICES=1
# AGENT_STAMP_INTERVAL_SEC=0
# AGENT_TRUST_ON_ROLLOVER=1
# AGENT_TRUST_EXPORT=1
# AGENT_AUTO_REBALANCE=0
# Ongoing rebalance: each agent tick, loop plan→rebalance until within bands or max steps (default on if EXECUTOR_PRIVATE_KEY)
# AGENT_REBALANCE_TO_TARGET=1
# AGENT_REBALANCE_MAX_STEPS_PER_TICK=8
# AGENT_REBALANCE_FROZEN_PHASE_ONLY=0
# Dev: amplify trust finalize `vote_return_bps` from tiny effective returns (default 1)
# TESTBOOSTTRUST=1
# Dev: synthetic profit for cycle-profits.json — each exported close draws uniform random in [-T/2, T] (T = this value, NAV 1e18 scale), pool = max(0, draw); npm run profit:export redraws
# TESTGAINS=
# Dev: min time-weight so votes near cycle end still get non-zero effective return (0..1)
# TRUST_MIN_TIME_WEIGHT_FLOOR=0.25
# Dev: ignore Uniswap pool for WETH; use synthetic oscillating USDC/WETH (dead testnet pools)
# TESTWETHOCCILATOR=true
# TESTWETH_OSCILLATOR_BASE_USDC=3000
# TESTWETH_OSCILLATOR_AMP=0.02
# TESTWETH_OSCILLATOR_PERIOD_SEC=90
# TESTWETH_OSCILLATOR_NOISE_BPS=50
#
# Advancing on-chain cycleId when wall-clock rolls (needs GOVERNANCE_PRIVATE_KEY); default on if key set
# AGENT_CLOSE_CYCLE_ON_ROLLOVER=1
# AGENT_CLOSE_CYCLE_RETRIES=3
# If AGENT_REBALANCE_TO_TARGET=0: one rebalance per closed window (EXECUTOR_PRIVATE_KEY); default on when target loop off
# AGENT_REBALANCE_ON_ROLLOVER=1
#
# Long-running (legacy): `cd apps/agent && npm run cycle:daemon`
# CYCLE_DAEMON_INTERVAL_SEC=60
# CYCLE_DAEMON_TRUST_EXPORT=1

# Contracts (after deploy) — must match `VITE_VAULT_ADDRESS` in `frontend/.env.local`
VAULT_ADDRESS=
GOVERNANCE_ADDRESS=
EXECUTOR_ADDRESS=

# Governance signer — `npm run close-cycle` / agent automatic `closeCycle` on wall-clock rollover (dev only)
# GOVERNANCE_PRIVATE_KEY=

# Tokens (optional overrides if not using defaults)
# WETH_ADDRESS=
# USDC_ADDRESS=

# Uniswap (optional API track / routing)
# UNISWAP_API_KEY=
# UNISWAP_SWAP_ROUTER_ADDRESS=
# UNISWAP_QUOTER_ADDRESS=

# Executor signing (dev only — use delegation / hardware in production narratives)
EXECUTOR_PRIVATE_KEY=

# `npm run rebalance` (apps/agent) — oracle vs pool guard + minOut (Base Sepolia defaults)
# REBALANCE_ORACLE_POOL_MAX_DEVIATION_BPS=2000
# REBALANCE_SLIPPAGE_BPS=100
# REBALANCE_DISABLE_ORACLE_POOL_GUARD=1

# Telegram
TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_WEBHOOK_URL=

# Synthesis submission automation
SYNTHESIS_BASE_URL=https://synthesis.devfolio.co
SYNTHESIS_PARTICIPANT_ID=
SYNTHESIS_TEAM_ID=
SYNTHESIS_PROJECT_UUID=038081098f4a4a758268ad23834672bd
SYNTHESIS_API_KEY=
# After publish: VIDEO_URL='https://...' npm run synthesis:set-video
