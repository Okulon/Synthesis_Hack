# Browser-safe vars only (VITE_* is exposed to the client — use a public RPC URL, not secrets).
#
# Required prefix: VITE_ — repo root uses VAULT_ADDRESS / CHAIN_RPC_URL but the dashboard must
# duplicate them here as VITE_VAULT_ADDRESS and VITE_RPC_URL (Vite does not read ../.env names).

# Same network as your vault (Base Sepolia default)
VITE_CHAIN_ID=84532

# HTTPS RPC (e.g. https://sepolia.base.org or Alchemy/Infura URL)
VITE_RPC_URL=https://sepolia.base.org

# Deployed DAOVault — same hex as repo-root `VAULT_ADDRESS` (not `VAULT_ADDRESS=` name here)
VITE_VAULT_ADDRESS=

# Optional: first block for log scans (deploy block avoids missing `AssetAllowed` / roles). Example last broadcast: 39039142
# VITE_ROLE_LOGS_FROM_BLOCK=39039142

# Optional: holder discovery (Transfer logs) — same idea as role scan; use deploy block after fresh deploy
# VITE_HOLDER_LOGS_FROM_BLOCK=39039142

# Optional: AllocationBallotCast logs — same deploy block works for new vaults
# VITE_ALLOCATION_VOTE_LOGS_FROM_BLOCK=39039142

# Optional: public GitHub repo (no trailing slash) — adds judge doc links in the footer
# VITE_SOURCE_REPO_URL=https://github.com/your-org/your-repo
