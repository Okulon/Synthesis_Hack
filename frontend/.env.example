# Browser-safe vars only (VITE_* is exposed to the client — use a public RPC URL, not secrets).
#
# Required prefix: VITE_ — repo root uses VAULT_ADDRESS / CHAIN_RPC_URL but the dashboard must
# duplicate them here as VITE_VAULT_ADDRESS and VITE_RPC_URL (Vite does not read ../.env names).

# Same network as your vault (Base Sepolia default)
VITE_CHAIN_ID=84532

# HTTPS RPC (e.g. https://sepolia.base.org or Alchemy/Infura URL)
VITE_RPC_URL=

# Deployed DAOVault — MUST be VITE_VAULT_ADDRESS=0x... (not VAULT_ADDRESS=)
VITE_VAULT_ADDRESS=

# Optional: first block for role discovery (RoleGranted/Revoked). Omit = last 100k blocks from head (see
# `DEFAULT_ROLE_LOOKBACK_BLOCKS` in `src/lib/vault.ts`). Set to `0` for full history (many RPC requests).
# VITE_ROLE_LOGS_FROM_BLOCK=39100600

# Optional: holder discovery range for the "Users" page (share Transfer logs).
# VITE_HOLDER_LOGS_FROM_BLOCK=39100600
